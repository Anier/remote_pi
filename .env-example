# Telegram Bot Settings
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ALLOWED_USERS=12345678,98765432
DEBUG_UPDATES=false

# Bot Rendering Settings
TELEGRAM_THROTTLE_MS=1000

# Default Model Settings
DEFAULT_MODEL_PROVIDER=anthropic
DEFAULT_MODEL_ID=claude-3-5-sonnet-latest

# API Keys (If not configured globally via 'pi login' or system env)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
