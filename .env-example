# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Whitelist of allowed Telegram user IDs (comma-separated)
TELEGRAM_ALLOWED_USERS=12345678,98765432

# OpenCode Server URL (default: http://localhost:4096)
OPENCODE_SERVER_URL=http://localhost:4096

# Basic Auth Credentials for OpenCode Server
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_SERVER_PASSWORD=your_server_password_here

# Default Model Configuration
DEFAULT_MODEL_PROVIDER=opencode
DEFAULT_MODEL_ID=big-pickle
